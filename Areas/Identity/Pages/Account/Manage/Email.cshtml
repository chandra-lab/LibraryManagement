@page
@model EmailModel
@{
    ViewData["Title"] = "Email Address";
    ViewData["ActivePage"] = ManageNavPages.Email;
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="px-4 py-3">
    <div class="card border-0 mb-3" style="background: linear-gradient(135deg, #0d6efd, #0a58ca); border-radius: 12px;">
        <div class="card-body py-3 px-4">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:50px;height:50px;min-width:50px;background:rgba(255,255,255,0.2);">
                    <i class="bi bi-person-fill text-white" style="font-size:1.4rem;"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-white">@User.Identity!.Name</h6>
                    <small class="text-white opacity-75">Library Management Account</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            @await Html.PartialAsync("_ProfileNav", "Email")
        </div>
        <div class="col-md-9">
            <div class="card border-0" style="border-radius:12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                <div class="card-header bg-white border-bottom py-3 px-4" style="border-radius:12px 12px 0 0;">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-envelope text-primary me-2"></i> Email Address
                    </h6>
                </div>
                <div class="card-body p-4">

                    <partial name="_StatusMessage" for="StatusMessage" />
                    @if (Model.IsEmailConfirmed)
                    {
                        <div class="alert alert-success py-2 mb-3">
                            <i class="bi bi-check-circle"></i> Your email is confirmed.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning py-2 mb-3">
                            <i class="bi bi-exclamation-triangle"></i> Your email is not confirmed.
                        </div>
                    }
                    <form id="email-form" method="post" asp-page-handler="ChangeEmail">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">
                                <i class="bi bi-envelope text-primary"></i> Current Email
                            </label>
                            <input asp-for="Email" class="form-control bg-light" disabled />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.NewEmail" class="form-label fw-semibold">
                                <i class="bi bi-envelope-plus text-primary"></i> New Email
                            </label>
                            <input asp-for="Input.NewEmail" class="form-control" placeholder="Enter new email" />
                            <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-envelope-check"></i> Update Email
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
