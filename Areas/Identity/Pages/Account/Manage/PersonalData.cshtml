@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="px-4 py-3">
    <div class="card border-0 mb-3" style="background: linear-gradient(135deg, #0d6efd, #0a58ca); border-radius: 12px;">
        <div class="card-body py-3 px-4">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:50px;height:50px;min-width:50px;background:rgba(255,255,255,0.2);">
                    <i class="bi bi-person-fill text-white" style="font-size:1.4rem;"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-white">@User.Identity!.Name</h6>
                    <small class="text-white opacity-75">Library Management Account</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            @await Html.PartialAsync("_ProfileNav", "PersonalData")
        </div>
        <div class="col-md-9">
            <div class="card border-0" style="border-radius:12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                <div class="card-header bg-white border-bottom py-3 px-4" style="border-radius:12px 12px 0 0;">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-database text-primary me-2"></i> Personal Data
                    </h6>
                </div>
                <div class="card-body p-4">

                    <div class="alert alert-info mb-3">
                        <i class="bi bi-info-circle"></i> Your account contains personal data you can download or delete.
                    </div>
                    <div class="card border-primary mb-3">
                        <div class="card-body d-flex justify-content-between align-items-center py-3">
                            <div>
                                <h6 class="fw-bold mb-1">Download Your Data</h6>
                                <small class="text-muted">Get a copy of all your account data.</small>
                            </div>
                            <form asp-page="./DownloadPersonalData" method="post">
                                <button type="submit" class="btn btn-primary btn-sm px-3"><i class="bi bi-download"></i> Download</button>
                            </form>
                        </div>
                    </div>
                    <div class="card border-danger">
                        <div class="card-body d-flex justify-content-between align-items-center py-3">
                            <div>
                                <h6 class="fw-bold mb-1 text-danger">Delete Account</h6>
                                <small class="text-muted">Permanently delete your account. Cannot be undone.</small>
                            </div>
                            <a asp-page="./DeletePersonalData" class="btn btn-danger btn-sm px-3"><i class="bi bi-trash"></i> Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
