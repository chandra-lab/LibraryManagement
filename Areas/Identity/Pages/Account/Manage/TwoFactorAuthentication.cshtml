@page
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-Factor Auth";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="px-4 py-3">
    <div class="card border-0 mb-3" style="background: linear-gradient(135deg, #0d6efd, #0a58ca); border-radius: 12px;">
        <div class="card-body py-3 px-4">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:50px;height:50px;min-width:50px;background:rgba(255,255,255,0.2);">
                    <i class="bi bi-person-fill text-white" style="font-size:1.4rem;"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-white">@User.Identity!.Name</h6>
                    <small class="text-white opacity-75">Library Management Account</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            @await Html.PartialAsync("_ProfileNav", "TwoFactorAuthentication")
        </div>
        <div class="col-md-9">
            <div class="card border-0" style="border-radius:12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                <div class="card-header bg-white border-bottom py-3 px-4" style="border-radius:12px 12px 0 0;">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-shield-lock text-primary me-2"></i> Two-Factor Auth
                    </h6>
                </div>
                <div class="card-body p-4">

                    <partial name="_StatusMessage" for="StatusMessage" />
                    @if (Model.Is2faEnabled)
                    {
                        <div class="alert alert-success mb-3">
                            <i class="bi bi-shield-check"></i> Two-factor authentication is <strong>enabled</strong>.
                        </div>
                        <div class="d-flex flex-column gap-2">
                            <a asp-page="./Disable2fa" class="btn btn-outline-danger"><i class="bi bi-shield-x"></i> Disable 2FA</a>
                            <a asp-page="./GenerateRecoveryCodes" class="btn btn-outline-secondary"><i class="bi bi-key"></i> Reset Recovery Codes</a>
                            <a asp-page="./EnableAuthenticator" class="btn btn-outline-primary"><i class="bi bi-qr-code"></i> Setup Authenticator</a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-3">
                            <i class="bi bi-shield-exclamation"></i> Two-factor authentication is <strong>disabled</strong>.
                        </div>
                        <a asp-page="./EnableAuthenticator" class="btn btn-primary"><i class="bi bi-shield-plus"></i> Enable 2FA</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
