@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="px-4 py-3">
    <div class="card border-0 mb-3" style="background: linear-gradient(135deg, #0d6efd, #0a58ca); border-radius: 12px;">
        <div class="card-body py-3 px-4">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:50px;height:50px;min-width:50px;background:rgba(255,255,255,0.2);">
                    <i class="bi bi-person-fill text-white" style="font-size:1.4rem;"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-white">@User.Identity!.Name</h6>
                    <small class="text-white opacity-75">Library Management Account</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            @await Html.PartialAsync("_ProfileNav", "Index")
        </div>
        <div class="col-md-9">
            <div class="card border-0" style="border-radius:12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                <div class="card-header bg-white border-bottom py-3 px-4" style="border-radius:12px 12px 0 0;">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-person text-primary me-2"></i> Profile
                    </h6>
                </div>
                <div class="card-body p-4">

                    <partial name="_StatusMessage" for="StatusMessage" />
                    <form id="profile-form" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <div class="mb-3">
                            <label asp-for="Username" class="form-label fw-semibold">
                                <i class="bi bi-at text-primary"></i> Username
                            </label>
                            <input asp-for="Username" class="form-control bg-light" disabled />
                            <small class="text-muted">Username cannot be changed.</small>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.PhoneNumber" class="form-label fw-semibold">
                                <i class="bi bi-telephone text-primary"></i> Phone Number
                            </label>
                            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Enter your phone number" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
