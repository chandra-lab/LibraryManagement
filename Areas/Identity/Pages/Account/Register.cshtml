@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white text-center py-3">
            <h4 class="mb-0"><i class="bi bi-person-plus"></i> Create Account</h4>
            <p class="mb-0 small">Join the Library Management System</p>
            </div>
            <div class="card-body p-4">

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">
                            <i class="bi bi-envelope"></i> Email Address
                        </label>
                        <input asp-for="Input.Email" class="form-control"
                               autocomplete="username" placeholder="Enter your email" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">
                            <i class="bi bi-lock"></i> Password
                        </label>
                        <input asp-for="Input.Password" class="form-control"
                               autocomplete="new-password" placeholder="Create a password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label">
                            <i class="bi bi-lock-fill"></i> Confirm Password
                        </label>
                        <input asp-for="Input.ConfirmPassword" class="form-control"
                               autocomplete="new-password" placeholder="Repeat your password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-person-plus"></i> Create Account
                        </button>
                    </div>
                </form>

                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <hr class="my-4" />
                    <p class="text-center text-muted small mb-3">
                        <i class="bi bi-info-circle"></i>
                        You can also register using your social media account
                    </p>
                    <form id="external-account" asp-page="./ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div class="d-grid gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                @if (provider.Name == "Google")
                                {
                                    <button type="submit" class="btn btn-outline-danger"
                                            name="provider" value="@provider.Name">
                                        <i class="bi bi-google"></i> Continue with Google
                                    </button>
                                }
                                else if (provider.Name == "GitHub")
                                {
                                    <button type="submit" class="btn btn-outline-dark"
                                            name="provider" value="@provider.Name">
                                        <i class="bi bi-github"></i> Continue with GitHub
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-outline-secondary"
                                            name="provider" value="@provider.Name">
                                        <i class="bi bi-box-arrow-in-right"></i>
                                        Continue with @provider.DisplayName
                                    </button>
                                }
                            }
                        </div>
                    </form>
                }

            </div>
            <div class="card-footer text-center text-muted py-3">
                Already have an account?
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl"
                   class="text-primary fw-bold">Sign in here</a>
            </div>
        </div>

        <div class="card mt-3 border-info shadow-sm">
            <div class="card-body py-2">
                <p class="text-muted small mb-1">
                    <i class="bi bi-shield-check text-info"></i>
                    <strong>Password requirements:</strong>
                </p>
                <ul class="text-muted small mb-0">
                    <li>Minimum 6 characters</li>
                    <li>At least one digit (0-9)</li>
                    <li>At least one uppercase letter</li>
                </ul>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
