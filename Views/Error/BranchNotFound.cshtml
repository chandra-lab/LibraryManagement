@model LibraryManagement.Models.ErrorViewModel
@{
    ViewData["Title"] = "Branch Not Found";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card border-danger shadow">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">
                    <i class="bi bi-building-x"></i> Branch Not Found
                </h4>
            </div>
            <div class="card-body py-5">
                <i class="bi bi-building-x text-danger" style="font-size: 4rem;"></i>
                <h2 class="mt-3">Library Branch Not Found</h2>
                <p class="lead text-muted">@Model.Message</p>
                <hr />
                <p class="text-muted">
                    <i class="bi bi-info-circle"></i>
                    Branch ID <strong>@Model.BranchId</strong> does not
                    exist in our system. It may have been removed
                    or the ID is incorrect.
                </p>
                @if (Model.ShowRequestId)
                {
                    <p class="text-muted small">
                        <strong>Request ID:</strong> @Model.RequestId
                    </p>
                }
                <div class="mt-4">
                    <a asp-controller="LibraryBranch" asp-action="Index"
                       class="btn btn-danger me-2">
                        <i class="bi bi-arrow-left"></i> Back to Branches
                    </a>
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-house"></i> Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>