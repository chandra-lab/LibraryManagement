@model LibraryManagement.Models.ErrorViewModel
@{
    ViewData["Title"] = "Book Unavailable";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card border-warning shadow">
            <div class="card-header bg-warning">
                <h4 class="mb-0">
                    <i class="bi bi-book-x"></i> Book Unavailable
                </h4>
            </div>
            <div class="card-body py-5">
                <i class="bi bi-book-x text-warning" style="font-size: 4rem;"></i>
                <h2 class="mt-3">Sorry, this book is unavailable!</h2>
                <p class="lead text-muted">@Model.Message</p>
                <hr />
                <p class="text-muted">
                    <i class="bi bi-info-circle"></i>
                    The book <strong>@Model.BookTitle</strong> currently
                    has no copies available for borrowing.
                    Please check back later or contact your branch.
                </p>
                @if (Model.ShowRequestId)
                {
                    <p class="text-muted small">
                        <strong>Request ID:</strong> @Model.RequestId
                    </p>
                }
                <div class="mt-4">
                    <a asp-controller="Book" asp-action="Index"
                       class="btn btn-warning me-2">
                        <i class="bi bi-arrow-left"></i> Back to Books
                    </a>
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-house"></i> Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>