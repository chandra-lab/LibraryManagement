@model LibraryManagement.Models.Book
@{
    ViewData["Title"] = "Delete Book";
}

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Delete Book</h4>
            </div>
            <div class="card-body">
                <p class="lead">Are you sure you want to delete this book?</p>
                <dl class="row">
                    <dt class="col-sm-4">Title</dt>
                    <dd class="col-sm-8"><strong>@Model.Title</strong></dd>
                    <dt class="col-sm-4">Author</dt>
                    <dd class="col-sm-8">@Model.Author?.FullName</dd>
                    <dt class="col-sm-4">Genre</dt>
                    <dd class="col-sm-8">@Model.Genre</dd>
                    <dt class="col-sm-4">Branch</dt>
                    <dd class="col-sm-8">@Model.LibraryBranch?.BranchName</dd>
                </dl>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i> This action cannot be undone.
                </div>
            </div>
            <div class="card-footer">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
