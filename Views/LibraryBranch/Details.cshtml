@model LibraryManagement.Models.LibraryBranch
@{
    ViewData["Title"] = Model.BranchName;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Branches</a></li>
        <li class="breadcrumb-item active">@Model.BranchName</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning">
                <h4 class="mb-0"><i class="bi bi-building"></i> @Model.BranchName
                    @if (Model.IsOpen)
                    {
                        <span class="badge bg-success ms-2">Open</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary ms-2">Closed</span>
                    }
                </h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@Model.Address, @Model.City</dd>
                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">@(Model.Phone ?? "N/A")</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@(Model.Email ?? "N/A")</dd>
                    <dt class="col-sm-4">Opening Hours</dt>
                    <dd class="col-sm-8">@(Model.OpeningHours ?? "N/A")</dd>
                    <dt class="col-sm-4">Manager</dt>
                    <dd class="col-sm-8">@(Model.ManagerName ?? "N/A")</dd>
                </dl>
            </div>
            <div class="card-footer">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header"><h6 class="mb-0">Books at this Branch (@Model.Books.Count)</h6></div>
                    <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                        @foreach (var book in Model.Books)
                        {
                            <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id" class="list-group-item list-group-item-action py-2">
                                <div class="d-flex justify-content-between">
                                    <small><strong>@book.Title</strong></small>
                                    <span class="badge bg-@(book.AvailableCopies > 0 ? "success" : "danger") ms-1">@book.AvailableCopies/@book.TotalCopies</span>
                                </div>
                                <small class="text-muted">@book.Author?.FullName</small>
                            </a>
                        }
                        @if (!Model.Books.Any()) { <div class="list-group-item text-muted">No books at this branch.</div> }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header"><h6 class="mb-0">Members (@Model.Customers.Count)</h6></div>
                    <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                        @foreach (var customer in Model.Customers)
                        {
                            <a asp-controller="Customer" asp-action="Details" asp-route-id="@customer.Id" class="list-group-item list-group-item-action py-2">
                                <div class="d-flex justify-content-between">
                                    <small><strong>@customer.FullName</strong></small>
                                    <span class="badge bg-@(customer.IsActive ? "success" : "secondary")">@(customer.IsActive ? "Active" : "Inactive")</span>
                                </div>
                                <small class="text-muted">@customer.Email</small>
                            </a>
                        }
                        @if (!Model.Customers.Any()) { <div class="list-group-item text-muted">No members registered.</div> }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
