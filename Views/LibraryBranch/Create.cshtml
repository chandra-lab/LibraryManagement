@model LibraryManagement.ViewModels.LibraryBranchViewModel
@{
    ViewData["Title"] = "Add Branch";
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Add New Library Branch</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="BranchName" class="form-label"></label>
                            <input asp-for="BranchName" class="form-control" />
                            <span asp-validation-for="BranchName" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="City" class="form-label"></label>
                            <input asp-for="City" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" type="email" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ManagerName" class="form-label"></label>
                            <input asp-for="ManagerName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OpeningHours" class="form-label"></label>
                            <input asp-for="OpeningHours" class="form-control" placeholder="e.g., Mon-Fri 9am-8pm" />
                        </div>
                        <div class="col-md-3">
                            <div class="form-check mt-4">
                                <input asp-for="IsOpen" class="form-check-input" type="checkbox" />
                                <label asp-for="IsOpen" class="form-check-label">Currently Open</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-warning"><i class="bi bi-save"></i> Save Branch</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
