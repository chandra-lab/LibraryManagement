@model IEnumerable<LibraryManagement.Models.LibraryBranch>
@{
    ViewData["Title"] = "Library Branches";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-building text-warning"></i> Library Branches</h2>
    <a asp-action="Create" class="btn btn-warning"><i class="bi bi-plus-circle"></i> Add Branch</a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by name or city..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-warning"><i class="bi bi-search"></i> Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-warning">
                <tr>
                    <th>Branch Name</th>
                    <th>City</th>
                    <th>Manager</th>
                    <th>Hours</th>
                    <th>Books</th>
                    <th>Members</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var branch in Model)
                {
                    <tr>
                        <td><strong>@branch.BranchName</strong></td>
                        <td>@branch.City</td>
                        <td>@branch.ManagerName</td>
                        <td><small>@branch.OpeningHours</small></td>
                        <td><span class="badge bg-primary">@branch.Books.Count</span></td>
                        <td><span class="badge bg-info">@branch.Customers.Count</span></td>
                        <td>
                            @if (branch.IsOpen)
                            {
                                <span class="badge bg-success">Open</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Closed</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@branch.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@branch.Id" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@branch.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No branches found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer text-muted">@Model.Count() branch(es)</div>
</div>
