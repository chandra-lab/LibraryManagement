@model LibraryManagement.Models.Author
@{
    ViewData["Title"] = "Delete Author";
}

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Delete Author</h4>
            </div>
            <div class="card-body">
                <p class="lead">Are you sure you want to delete <strong>@Model.FullName</strong>?</p>
                <dl class="row">
                    <dt class="col-sm-4">Nationality</dt>
                    <dd class="col-sm-8">@Model.Nationality</dd>
                    <dt class="col-sm-4">Books</dt>
                    <dd class="col-sm-8">
                        @if (Model.Books.Any())
                        {
                            <span class="badge bg-warning">@Model.Books.Count book(s) will be affected</span>
                        }
                        else { <span class="text-muted">None</span> }
                    </dd>
                </dl>
                <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> This action cannot be undone.</div>
            </div>
            <div class="card-footer">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
