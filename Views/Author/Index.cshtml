@model IEnumerable<LibraryManagement.Models.Author>
@{
    ViewData["Title"] = "Authors";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-lines-fill text-success"></i> Authors</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Add Author</a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by name..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-success"><i class="bi bi-search"></i> Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-success">
                <tr>
                    <th>Name</th>
                    <th>Nationality</th>
                    <th>Birth Year</th>
                    <th>Books</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var author in Model)
                {
                    <tr>
                        <td><strong>@author.FullName</strong></td>
                        <td>@author.Nationality</td>
                        <td>@author.BirthYear</td>
                        <td><span class="badge bg-info">@author.Books.Count</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@author.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@author.Id" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@author.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No authors found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer text-muted">@Model.Count() author(s)</div>
</div>
